---
import '../styles/global.css';

const {
  title = 'NOCTA — Traiteur & Chef privé à Paris | Catering haut de gamme',
  description = "NOCTA, traiteur haut de gamme à Paris. Chef privé, dîners privés, événements corporate et expériences immersives en Île-de-France. Formés en cuisine étoilée, service sur-mesure.",
} = Astro.props;

const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : null;
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-5KRLSJ9P');</script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- PRECONNECT — réduit la latence DNS/TLS pour Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- PRELOAD — image LCP hero : navigateur démarre le téléchargement avant de parser le body -->
    <link
      rel="preload"
      as="image"
      href="/images/nocta-assiette-hero1-800w.webp"
      imagesrcset="/images/nocta-assiette-hero1-400w.webp 400w, /images/nocta-assiette-hero1-800w.webp 800w, /images/nocta-assiette-hero1-1200w.webp 1200w"
      imagesizes="100vw"
    />

    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="NOCTA Catering" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://www.noctaparis.fr/images/og-image.jpeg" />
    <meta property="og:url" content="https://www.noctaparis.fr" />
    <meta property="og:site_name" content="NOCTA" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://www.noctaparis.fr/images/og-image.jpeg" />

    <!-- Canonical -->
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.svg" />
    <meta name="theme-color" content="#0A0A0A" />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FoodEstablishment",
        "name": "NOCTA Catering",
        "description": "Traiteur haut de gamme à Paris. Chef privé, dîners privés, événements corporate et expériences gastronomiques immersives en Île-de-France.",
        "url": "https://www.noctaparis.fr",
        "telephone": "+33650011616",
        "email": "contact@noctaparis.fr",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "2 bis rue Edith Cavell",
          "addressLocality": "Courbevoie",
          "postalCode": "92400",
          "addressRegion": "Île-de-France",
          "addressCountry": "FR"
        },
        "servesCuisine": "Gastronomie française",
        "priceRange": "€€€€",
        "areaServed": ["Paris", "Île-de-France", "La Défense", "France"],
        "founder": [
          {"@type": "Person", "name": "Hugo Vinatier", "jobTitle": "Chef"},
          {"@type": "Person", "name": "Enzo Ryon", "jobTitle": "Sommelier et Maître d'hôtel"}
        ]
      }
    </script>

    <title>{title}</title>

    <!-- Google Fonts — non-bloquant (media trick : appliqué après le rendu initial) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" />
    </noscript>

    <!-- GLightbox CSS — différé : galerie below the fold, inutile au chargement initial -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css"
      media="print"
      onload="this.media='all'"
    />
    <script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5KRLSJ9P"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <slot />

    <!-- Scroll reveal script global -->
    <script>
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReducedMotion) {
        // Skip animations — make all elements immediately visible
        document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
        );

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
      }
    </script>
  </body>
</html>
