---
const pathname = Astro.url.pathname;

const navLinks = [
  { label: 'Notre Maison', href: '/maison' },
  { label: 'Prestations',  href: '/prestations' },
  { label: 'Journal',      href: '/journal' },
  { label: 'Contact',      href: '/contact' },
];
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 text-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 h-20 flex items-center justify-between">

    <a href="/" class="flex items-center logo-animated" aria-label="NOCTA - Accueil">
      <span class="logo-svg" aria-hidden="true"></span>
    </a>

    <nav class="hidden lg:flex items-center gap-10">
      {navLinks.map(link => {
        const isActive = pathname === link.href || pathname.startsWith(link.href + '/');
        return (
          <a href={link.href} class={`font-sans text-sm font-light tracking-widest uppercase text-inherit relative after:absolute after:bottom-0 after:left-0 after:h-px after:bg-current after:transition-all after:duration-300 hover:after:w-full transition-opacity duration-200 hover:opacity-60 ${isActive ? 'after:w-full' : 'after:w-0'}`}>
            {link.label}
          </a>
        );
      })}
    </nav>

    <a href="/contact" class="hidden lg:inline-flex items-center gap-2 font-sans text-sm font-light tracking-widest uppercase border border-current text-inherit px-6 py-3 transition-all duration-300 hover:bg-nocta-black hover:text-nocta-cream hover:border-nocta-black">
      Demander un devis
    </a>

    <button id="burger" class="lg:hidden flex flex-col gap-1.5 p-2" aria-label="Menu" aria-expanded="false">
      <span class="block w-6 h-px bg-current transition-all duration-300"></span>
      <span class="block w-6 h-px bg-current transition-all duration-300"></span>
      <span class="block w-4 h-px bg-current transition-all duration-300"></span>
    </button>
  </div>

  <div id="mobile-menu" class="lg:hidden hidden bg-nocta-cream border-t border-nocta-black/10">
    <nav class="max-w-7xl mx-auto px-6 py-8 flex flex-col gap-6">
      {navLinks.map(link => (
        <a href={link.href} class="font-sans text-base font-light tracking-widest uppercase text-nocta-black">
          {link.label}
        </a>
      ))}
      <a href="/contact" class="font-sans text-sm font-light tracking-widest uppercase border border-nocta-black text-nocta-black px-6 py-3 text-center hover:bg-nocta-black hover:text-nocta-cream transition-all duration-300">
        Demander un devis
      </a>
    </nav>
  </div>
</header>

<style>
  /* Logo externalisé (public/images/nocta-logo.svg) rendu en CSS mask :
     background-color: currentColor préserve le swap blanc → noir au scroll. */
  .logo-svg {
    display: block;
    height: 52px;
    aspect-ratio: 170 / 75;
    background-color: currentColor;
    -webkit-mask: url('/images/nocta-logo.svg') no-repeat center / contain;
    mask: url('/images/nocta-logo.svg') no-repeat center / contain;
  }

  @keyframes logoFadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .logo-animated {
    animation: logoFadeUp 0.8s ease-out forwards;
  }
</style>

<script>
  const header = document.getElementById('header');
  const burger = document.getElementById('burger');
  const mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      header?.classList.add('bg-nocta-cream/95', 'backdrop-blur-sm', 'shadow-sm', 'text-nocta-black');
      header?.classList.remove('text-white');
    } else {
      header?.classList.remove('bg-nocta-cream/95', 'backdrop-blur-sm', 'shadow-sm', 'text-nocta-black');
      header?.classList.add('text-white');
    }
  });

  burger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden', !isOpen);
    burger.setAttribute('aria-expanded', String(isOpen));
  });
</script>