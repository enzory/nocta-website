    display: block;
    height: 36px;
    aspect-ratio: 170 / 75;
    background-color: currentColor;
    -webkit-mask: url('/images/nocta-logo.svg') no-repeat center / contain;
    mask: url('/images/nocta-logo.svg') no-repeat center / contain;
  }
</style>
