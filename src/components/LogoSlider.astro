---
import levisSrc          from '../assets/logos/levis.svg?url';
import biologiqueSrc     from '../assets/logos/biologique-recherche.svg?url';
import galionSrc         from '../assets/logos/the-galion.svg?url';
import columbusSrc       from '../assets/logos/colombus-consulting.svg?url';
import jusMundiSrc       from '../assets/logos/jus-mundi.svg?url';
import aaConseilSrc      from '../assets/logos/aa-conseil.svg?url';

const logos = [
  { src: levisSrc,       alt: "Levi's",               h: 36 },
  { src: biologiqueSrc,  alt: 'Biologique Recherche',  h: 32 },
  { src: galionSrc,      alt: 'The Galion',            h: 48 },
  { src: columbusSrc,    alt: 'Colombus Consulting',   h: 40 },
  { src: jusMundiSrc,    alt: 'Jus Mundi',             h: 44 },
  { src: aaConseilSrc,   alt: 'AA Conseil',            h: 44 },
];
---

<section class="bg-nocta-cream border-t border-[#0A0A0A]/10 border-b py-16">
  <p class="font-sans text-xs tracking-widest uppercase text-[#0A0A0A]/40 text-center mb-10">
    ILS NOUS FONT CONFIANCE
  </p>

  <div class="logo-slider-outer">
    <div class="logo-track">
      <!-- SET 1 -->
      {logos.map((logo) => (
        <div class="logo-item">
          <img src={logo.src} alt={logo.alt} style={`height: ${logo.h}px`} loading="lazy" draggable="false" />
        </div>
      ))}
      <!-- SET 2 — copie identique pour boucle seamless -->
      {logos.map((logo) => (
        <div class="logo-item" aria-hidden="true">
          <img src={logo.src} alt={logo.alt} style={`height: ${logo.h}px`} loading="lazy" draggable="false" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes scroll-logos {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .logo-slider-outer {
    overflow: hidden;
    width: 100%;
  }

  .logo-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: scroll-logos 30s linear infinite;
    isolation: isolate;
    will-change: transform;
  }

  .logo-track:hover {
    animation-play-state: paused;
  }

  .logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 70px;
    flex-shrink: 0;
  }

  .logo-item img {
    width: auto;
    max-width: 120px;
    object-fit: contain;
    opacity: 0.5;
    transition: opacity 0.3s ease;
    user-select: none;
    -webkit-user-drag: none;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  .logo-item:hover img {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .logo-item {
      margin: 0 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: 40px;
      padding: 0 24px;
    }
  }
</style>
