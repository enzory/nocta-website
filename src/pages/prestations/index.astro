---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
---

<Layout
  title="Nos Prestations — NOCTA"
  description="NOCTA propose trois formats d'expériences culinaires sur-mesure : NOCTA Private, Corporate et Signature. Découvrez notre offre à Paris et en Île-de-France."
>
  <Header />

  <main>

    <!-- Hero minimal -->
    <section class="bg-nocta-cream pt-40 pb-24 lg:pt-52 lg:pb-32">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <p class="font-sans text-xs font-light tracking-[0.4em] uppercase text-nocta-grey mb-6 animate-fade-up" style="animation-delay: 0.2s; opacity: 0;">
          Nos Prestations
        </p>
        <h1 class="font-serif text-5xl lg:text-7xl xl:text-8xl font-light italic text-nocta-black leading-[1.05] max-w-4xl animate-fade-up" style="animation-delay: 0.4s; opacity: 0;">
          Trois formats.<br/>
          <em class="not-italic font-extralight">Une seule exigence.</em>
        </h1>
      </div>
    </section>

    <!-- Cards -->
    <section class="bg-nocta-cream border-t border-nocta-black/10 py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-px bg-nocta-black/15">

          <!-- 01 — NOCTA Private -->
          <a href="/prestations/private" class="group flex flex-col bg-nocta-cream p-10 hover:bg-nocta-black/[.03] transition-colors duration-300 reveal">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-10">01</p>
            <h2 class="font-serif text-4xl lg:text-5xl font-light italic text-nocta-black leading-[1.1] mb-6">
              NOCTA<br/>Private
            </h2>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey mb-12">
              L'art de recevoir chez soi. Dîners intimes, anniversaires, célébrations familiales. Authenticité, discrétion, précision.
            </p>
            <div class="mt-auto flex items-center gap-3 font-sans text-xs font-light tracking-widest uppercase text-nocta-black/50 group-hover:text-nocta-black transition-colors duration-300">
              <span class="relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-nocta-black after:transition-all after:duration-300 group-hover:after:w-full">
                Découvrir
              </span>
              <span class="w-6 h-px bg-current inline-block group-hover:w-10 transition-all duration-300"></span>
            </div>
          </a>

          <!-- 02 — NOCTA Corporate -->
          <a href="/prestations/corporate" class="group flex flex-col bg-nocta-cream p-10 hover:bg-nocta-black/[.03] transition-colors duration-300 reveal" style="transition-delay: 0.1s">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-10">02</p>
            <h2 class="font-serif text-4xl lg:text-5xl font-light italic text-nocta-black leading-[1.1] mb-6">
              NOCTA<br/>Corporate
            </h2>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey mb-12">
              La gastronomie comme vecteur d'image. Cocktails de lancement, dîners de gala, comités de direction. Rigueur et élégance.
            </p>
            <div class="mt-auto flex items-center gap-3 font-sans text-xs font-light tracking-widest uppercase text-nocta-black/50 group-hover:text-nocta-black transition-colors duration-300">
              <span class="relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-nocta-black after:transition-all after:duration-300 group-hover:after:w-full">
                Découvrir
              </span>
              <span class="w-6 h-px bg-current inline-block group-hover:w-10 transition-all duration-300"></span>
            </div>
          </a>

          <!-- 03 — NOCTA Signature -->
          <a href="/prestations/signature" class="group flex flex-col bg-nocta-cream p-10 hover:bg-nocta-black/[.03] transition-colors duration-300 reveal" style="transition-delay: 0.2s">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-10">03</p>
            <h2 class="font-serif text-4xl lg:text-5xl font-light italic text-nocta-black leading-[1.1] mb-6">
              NOCTA<br/>Signature
            </h2>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey mb-12">
              La création comme expérience. Gastronomie comme terrain d'expression artistique, où technique rencontre émotion. Notre vision la plus libre.
            </p>
            <div class="mt-auto flex items-center gap-3 font-sans text-xs font-light tracking-widest uppercase text-nocta-black/50 group-hover:text-nocta-black transition-colors duration-300">
              <span class="relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-nocta-black after:transition-all after:duration-300 group-hover:after:w-full">
                Découvrir
              </span>
              <span class="w-6 h-px bg-current inline-block group-hover:w-10 transition-all duration-300"></span>
            </div>
          </a>

        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-nocta-black py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center reveal">
        <h2 class="font-serif text-4xl lg:text-6xl font-light italic text-nocta-cream leading-tight mb-10">
          Parlons de votre événement.
        </h2>
        <a href="/contact" class="inline-flex items-center font-sans text-sm font-light tracking-widest uppercase bg-nocta-cream text-nocta-black px-10 py-4 hover:bg-white transition-all duration-300">
          Demander un devis
        </a>
      </div>
    </section>

  </main>

  <footer class="bg-nocta-black border-t border-nocta-cream/10 py-10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 flex flex-col lg:flex-row items-center justify-between gap-4">
      <span class="font-serif text-lg tracking-[0.3em] text-nocta-cream/60 uppercase">NOCTA</span>
      <p class="font-sans text-xs font-light text-nocta-cream/30 tracking-wide">
        © 2025 NOCTA — H+E Catering SARL · Paris & Île-de-France
      </p>
      <a href="/mentions-legales" class="font-sans text-xs font-light tracking-widest uppercase text-nocta-cream/30 hover:text-nocta-cream/60 transition-colors">
        Mentions légales
      </a>
    </div>
  </footer>

</Layout>
