---
import Layout from '../../layouts/layout.astro';
import Header from '../../components/header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Nos Prestations — Traiteur & Catering Paris | NOCTA Private, Corporate, Signature"
  description="Traiteur à Paris pour particuliers et entreprises. NOCTA propose trois formats sur-mesure : dîners privés à domicile, catering événementiel corporate et expériences gastronomiques immersives en Île-de-France."
>
  <Header />

  <main>

    <!-- Hero -->
    <section class="relative flex flex-col justify-end bg-nocta-black overflow-hidden" style="min-height: 50vh;">
      <div class="absolute inset-0">
        <img
          src="/images/nocta-table-fleure-2.webp"
          alt="Nos prestations — catering sur-mesure Paris, NOCTA Private Corporate Signature"
          width="1800"
          height="2400"
          class="w-full h-full object-cover"
          style="object-position: center center;"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-black/50"></div>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 pt-40 pb-16 lg:pt-52 lg:pb-20 w-full">
        <p class="font-sans text-xs font-light tracking-[0.4em] uppercase text-nocta-cream/60 mb-6 animate-fade-up" style="animation-delay: 0.2s; opacity: 0;">
          Nos Prestations
        </p>
        <h1 class="font-serif text-3xl md:text-5xl lg:text-7xl xl:text-8xl font-light italic text-nocta-cream leading-[1.05] max-w-4xl animate-fade-up" style="animation-delay: 0.4s; opacity: 0;">
          Trois formats.<br/>
          <em class="not-italic font-extralight">Une seule exigence.</em>
        </h1>
      </div>
    </section>

    <!-- Cards -->
    <section class="bg-nocta-cream border-t border-nocta-black/10 py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-px bg-nocta-black/15">

          <!-- 01 — NOCTA Private -->
          <a href="/prestations/private" class="group flex flex-col bg-nocta-cream p-8 hover:bg-nocta-black/[.03] transition-colors duration-300 reveal">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-10">01</p>
            <h2 class="font-serif text-4xl lg:text-5xl font-light italic text-nocta-black leading-[1.1] mb-6">
              NOCTA<br/>Private
            </h2>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey mb-12">
              Dîners à domicile, anniversaires, célébrations familiales. Nous gérons l'intégralité - pour que vous soyez présent à vos invités.
            </p>
            <div class="mt-auto flex items-center gap-3 font-sans text-xs font-light tracking-widest uppercase text-nocta-black/50 group-hover:text-nocta-black transition-colors duration-300">
              <span class="relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-nocta-black after:transition-all after:duration-300 group-hover:after:w-full">
                Découvrir
              </span>
              <span class="w-6 h-px bg-current inline-block group-hover:w-10 transition-all duration-300"></span>
            </div>
          </a>

          <!-- 02 — NOCTA Corporate -->
          <a href="/prestations/corporate" class="group flex flex-col bg-nocta-cream p-8 hover:bg-nocta-black/[.03] transition-colors duration-300 reveal" style="transition-delay: 0.1s">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-10">02</p>
            <h2 class="font-serif text-4xl lg:text-5xl font-light italic text-nocta-black leading-[1.1] mb-6">
              NOCTA<br/>Corporate
            </h2>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey mb-12">
              Cocktails de lancement, dîners de gala, comités de direction. Une gastronomie à la hauteur de votre image.
            </p>
            <div class="mt-auto flex items-center gap-3 font-sans text-xs font-light tracking-widest uppercase text-nocta-black/50 group-hover:text-nocta-black transition-colors duration-300">
              <span class="relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-nocta-black after:transition-all after:duration-300 group-hover:after:w-full">
                Découvrir
              </span>
              <span class="w-6 h-px bg-current inline-block group-hover:w-10 transition-all duration-300"></span>
            </div>
          </a>

          <!-- 03 — NOCTA Signature -->
          <a href="/prestations/signature" class="group flex flex-col bg-nocta-cream p-8 hover:bg-nocta-black/[.03] transition-colors duration-300 reveal" style="transition-delay: 0.2s">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-10">03</p>
            <h2 class="font-serif text-4xl lg:text-5xl font-light italic text-nocta-black leading-[1.1] mb-6">
              NOCTA<br/>Signature
            </h2>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey mb-12">
              Un format entièrement sur-mesure - cuisine, vins et scénographie composent une expérience construite de bout en bout.
            </p>
            <div class="mt-auto flex items-center gap-3 font-sans text-xs font-light tracking-widest uppercase text-nocta-black/50 group-hover:text-nocta-black transition-colors duration-300">
              <span class="relative after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-nocta-black after:transition-all after:duration-300 group-hover:after:w-full">
                Découvrir
              </span>
              <span class="w-6 h-px bg-current inline-block group-hover:w-10 transition-all duration-300"></span>
            </div>
          </a>

        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-nocta-cream border-t border-nocta-black/10 py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">

        <div class="mb-16 reveal">
          <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-4">Questions fréquentes</p>
          <h2 class="font-serif text-2xl md:text-4xl lg:text-5xl font-light italic text-nocta-black leading-tight">
            Ce que nos clients nous demandent.
          </h2>
        </div>

        <div class="max-w-3xl">

          <!-- Q1 -->
          <div class="border-t border-nocta-black/10 py-8 reveal" style="transition-delay: 0.05s">
            <h3 class="font-serif text-xl lg:text-2xl font-light italic text-nocta-black mb-4">Quel est le tarif par personne ?</h3>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey">
              Tout dépend du format choisi. Le lieu, la présence de personnel de service, le type d'événement, la présence du chef sur place et les boissons font varier le prix. La location de matériel ou un menu avec des mets plus coûteux s'y ajoutent. Plutôt que de vous faire choisir dans un catalogue, nous travaillons sur mesure. Notre minimum de commande est de 500&nbsp;€&nbsp;HT, hors frais de livraison.
            </p>
          </div>

          <!-- Q2 -->
          <div class="border-t border-nocta-black/10 py-8 reveal" style="transition-delay: 0.1s">
            <h3 class="font-serif text-xl lg:text-2xl font-light italic text-nocta-black mb-4">Vous déplacez-vous en dehors de Paris ?</h3>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey">
              Oui, nous intervenons dans toute la France. Les frais de transport sont à la charge du client. Pour les événements nécessitant de rester sur place, les frais d'hébergement de notre équipe sont également à prévoir.
            </p>
          </div>

          <!-- Q3 -->
          <div class="border-t border-nocta-black/10 py-8 reveal" style="transition-delay: 0.15s">
            <h3 class="font-serif text-xl lg:text-2xl font-light italic text-nocta-black mb-4">Fournissez-vous la vaisselle ?</h3>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey">
              Oui, nous proposons un service de location. Nous pouvons fournir et apporter notre propre vaisselle, la verrerie ainsi que le linge de table.
            </p>
          </div>

          <!-- Q4 -->
          <div class="border-t border-nocta-black/10 py-8 reveal" style="transition-delay: 0.2s">
            <h3 class="font-serif text-xl lg:text-2xl font-light italic text-nocta-black mb-4">Que devons-nous fournir ?</h3>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey">
              Un maximum d'indications sur le lieu, sur la façon dont vous imaginez la soirée et sur vos attentes. C'est le plus important pour construire une prestation juste. Une fois cela établi, nous nous occupons de tout le reste.
            </p>
          </div>

          <!-- Q5 -->
          <div class="border-t border-nocta-black/10 py-8 reveal" style="transition-delay: 0.25s">
            <h3 class="font-serif text-xl lg:text-2xl font-light italic text-nocta-black mb-4">Combien de temps à l'avance faut-il réserver ?</h3>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey">
              Cela dépend du format. Pour un dîner privé de 5 à 8 couverts ou une livraison de plateaux-repas, nous pouvons intervenir sous 24 à 36 heures si notre planning le permet. Pour des événements plus conséquents, il faut anticiper davantage.
            </p>
          </div>

          <!-- Q6 -->
          <div class="border-t border-b border-nocta-black/10 py-8 reveal" style="transition-delay: 0.3s">
            <h3 class="font-serif text-xl lg:text-2xl font-light italic text-nocta-black mb-4">Proposez-vous des menus adaptés aux régimes alimentaires ?</h3>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey">
              Oui, nous nous adaptons à tous les régimes et à toutes les allergies : végan, végétarien, sans gluten, sans porc, et tout autre besoin spécifique. Il suffit de nous le préciser lors de la prise de contact.
            </p>
          </div>

        </div>

      </div>
    </section>

    <!-- CTA -->
    <section class="bg-nocta-black py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center reveal">
        <h2 class="font-serif text-2xl md:text-4xl lg:text-6xl font-light italic text-nocta-cream leading-tight mb-10">
          Parlons de votre événement.
        </h2>
        <a href="/contact" class="inline-flex items-center font-sans text-sm font-light tracking-widest uppercase bg-nocta-cream text-nocta-black px-8 py-3 hover:bg-white transition-all duration-300">
          Demander un devis
        </a>
      </div>
    </section>

  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Quel est le tarif par personne pour un traiteur à Paris ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Le tarif dépend du format choisi : lieu, personnel de service, type d'événement, présence du chef, boissons et location de matériel. NOCTA travaille sur mesure avec un minimum de commande de 500 € HT hors frais de livraison."
        }
      },
      {
        "@type": "Question",
        "name": "Le traiteur NOCTA se déplace-t-il en dehors de Paris ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui, NOCTA intervient dans toute la France. Les frais de transport sont à la charge du client. Pour les événements nécessitant un séjour sur place, les frais d'hébergement de l'équipe sont également à prévoir."
        }
      },
      {
        "@type": "Question",
        "name": "Le traiteur fournit-il la vaisselle et le linge de table ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui, NOCTA propose un service de location incluant vaisselle, verrerie et linge de table."
        }
      },
      {
        "@type": "Question",
        "name": "Que doit-on fournir pour un dîner avec un traiteur ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Un maximum d'indications sur le lieu, le déroulé souhaité et vos attentes. NOCTA s'occupe de tout le reste : cuisine, service, mise en place et rangement."
        }
      },
      {
        "@type": "Question",
        "name": "Combien de temps à l'avance faut-il réserver un traiteur à Paris ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Pour un dîner privé de 5 à 8 couverts ou une livraison de plateaux-repas, NOCTA peut intervenir sous 24 à 36 heures selon disponibilité. Pour des événements plus conséquents, il est recommandé d'anticiper davantage."
        }
      },
      {
        "@type": "Question",
        "name": "Le traiteur propose-t-il des menus végétariens, végan ou sans gluten ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui, NOCTA s'adapte à tous les régimes alimentaires et allergies : végan, végétarien, sans gluten, sans porc et tout autre besoin spécifique."
        }
      }
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://www.noctaparis.fr/"},
      {"@type": "ListItem", "position": 2, "name": "Prestations", "item": "https://www.noctaparis.fr/prestations"}
    ]
  })} />

</Layout>
