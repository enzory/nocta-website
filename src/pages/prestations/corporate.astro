---
import Layout from '../../layouts/layout.astro';
import Header from '../../components/header.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
---

<Layout
  title="NOCTA Corporate — Traiteur Événementiel Paris La Défense | Dîners & Cocktails d'entreprise"
  description="Traiteur événementiel à Paris et La Défense. NOCTA Corporate assure cocktails de lancement, dîners de gala, comités de direction et déjeuners d'affaires — service gastronomique haut de gamme pour entreprises."
>
  <Header />

  <main>

    <!-- Hero -->
    <section class="relative min-h-[50vh] lg:min-h-[70vh] flex flex-col justify-end bg-nocta-black overflow-hidden">
      <div class="absolute inset-0">
        <img
          src="/images/reception-levis-corporate.webp"
          alt="Traiteur corporate Paris La Défense — cocktail dîner d'entreprise NOCTA"
          width="2400"
          height="1375"
          class="w-full h-full object-cover object-center"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-black/50"></div>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-20 lg:pb-28 w-full">
        <a href="/prestations" class="inline-flex items-center gap-3 font-sans text-xs tracking-widest uppercase text-nocta-cream/60 hover:text-nocta-cream transition-colors duration-200 mb-12 animate-fade-up" style="animation-delay: 0.1s; opacity: 0;">
          <span class="w-6 h-px bg-current inline-block"></span>
          Nos Prestations
        </a>
        <p class="font-sans text-xs font-light tracking-[0.4em] uppercase text-nocta-cream/60 mb-6 animate-fade-up" style="animation-delay: 0.2s; opacity: 0;">
          02
        </p>
        <h1 class="font-serif text-3xl md:text-5xl lg:text-7xl xl:text-8xl font-light italic text-nocta-cream leading-[1.05] mb-6 animate-fade-up" style="animation-delay: 0.35s; opacity: 0;">
          NOCTA Corporate
        </h1>
        <p class="font-sans text-base lg:text-lg font-light text-nocta-cream/70 animate-fade-up" style="animation-delay: 0.5s; opacity: 0;">
          La gastronomie comme levier d'image.
        </p>
      </div>
    </section>

    <!-- About -->
    <section class="bg-nocta-black py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">

          <div class="reveal">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-cream/40 mb-4">Notre approche</p>
            <h2 class="font-serif text-2xl md:text-4xl lg:text-5xl font-light italic text-nocta-cream leading-tight">
              Une prestation à la hauteur de vos enjeux.
            </h2>
          </div>

          <div class="reveal" style="transition-delay: 0.15s">
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-cream/60 mb-6">
              NOCTA Corporate s'adresse aux entreprises qui considèrent la gastronomie comme un levier d'influence - pas un simple repas de travail. Chaque événement est une occasion d'affirmer votre identité et de marquer durablement vos interlocuteurs.
            </p>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-cream/60">
              Nous sommes à l'aise dans les environnements exigeants : timing serré, confidentialité, logistique complexe. Nous les anticipons et les gérons - pour que vous n'ayez qu'à vous concentrer sur vos invités.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- Approach image -->
    <div class="w-full h-[400px] overflow-hidden" style="background-color: #EEEBE3;">
      <img src="/images/table-fleurie-v2-800w.webp"
        srcset="/images/table-fleurie-v2-400w.webp 400w, /images/table-fleurie-v2-800w.webp 800w, /images/table-fleurie-v2-1200w.webp 1200w, /images/table-fleurie-v2.webp 2000w"
        sizes="100vw"
        alt="Table fleurie tulipes et bougies — dîner corporate gastronomique NOCTA Paris"
        width="2000" height="1500" loading="lazy"
        class="w-full h-full object-cover object-center" />
    </div>

    <!-- Formats -->
    <section class="bg-nocta-cream py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">

        <div class="mb-16 reveal">
          <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-4">Nos formats</p>
          <h2 class="font-serif text-2xl md:text-4xl lg:text-5xl font-light italic text-nocta-black leading-tight">
            Ce que nous proposons.
          </h2>
        </div>

        <div>
          <div class="border-t border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.05s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">01</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Cocktail de lancement</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">Mise en bouche soignée, service fluide, image maîtrisée.</p>
            </div>
          </div>
          <div class="border-t border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.1s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">02</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Dîner de gala</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">De la mise en place à la dernière assiette, nous gérons tout.</p>
            </div>
          </div>
          <div class="border-t border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.15s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">03</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Déjeuner confidentiel</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">Petit format, haute exigence. Pour les conversations qui comptent.</p>
            </div>
          </div>
          <div class="border-t border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.2s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">04</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Comité de direction</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">Un cadre gastronomique qui donne le ton de la réunion.</p>
            </div>
          </div>
          <div class="border-t border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.25s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">05</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Séminaire</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">Restauration haut de gamme sur une ou plusieurs journées.</p>
            </div>
          </div>
          <div class="border-t border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.3s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">06</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Plateaux-repas</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">Livraison soignée pour vos équipes. Le même soin, un format adapté.</p>
            </div>
          </div>
          <div class="border-t border-b border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.35s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">07</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Buffet</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">Mise en place complète, produits de qualité, service sur place si souhaité.</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <CallToAction />

  </main>

  <Footer />

</Layout>
