---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="NOCTA Private — Dîners privés & Chef à domicile · NOCTA"
  description="NOCTA Private : dîners intimes, anniversaires d'exception, célébrations familiales et chef à domicile à Paris et en Île-de-France."
>
  <Header />

  <main>

    <!-- Hero -->
    <section class="relative min-h-[50vh] lg:min-h-[70vh] flex flex-col justify-end bg-nocta-black overflow-hidden">
      <div class="absolute inset-0">
        <img
          src="/images/nocta-table-haussmann.jpg"
          alt="NOCTA Private"
          class="w-full h-full object-cover"
          style="object-position: center 35%;"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-black/50"></div>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-20 lg:pb-28 w-full">
        <a href="/prestations" class="inline-flex items-center gap-3 font-sans text-xs tracking-widest uppercase text-nocta-cream/60 hover:text-nocta-cream transition-colors duration-200 mb-12 animate-fade-up" style="animation-delay: 0.1s; opacity: 0;">
          <span class="w-6 h-px bg-current inline-block"></span>
          Nos Prestations
        </a>
        <p class="font-sans text-xs font-light tracking-[0.4em] uppercase text-nocta-cream/60 mb-6 animate-fade-up" style="animation-delay: 0.2s; opacity: 0;">
          01
        </p>
        <h1 class="font-serif text-3xl md:text-5xl lg:text-7xl xl:text-8xl font-light italic text-nocta-cream leading-[1.05] mb-6 animate-fade-up" style="animation-delay: 0.35s; opacity: 0;">
          NOCTA Private
        </h1>
        <p class="font-sans text-base lg:text-lg font-light text-nocta-cream/70 animate-fade-up" style="animation-delay: 0.5s; opacity: 0;">
          L'art de recevoir chez soi.
        </p>
      </div>
    </section>

    <!-- About -->
    <section class="bg-nocta-black py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">

          <div class="reveal">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-cream/40 mb-4">Notre approche</p>
            <h2 class="font-serif text-2xl md:text-4xl lg:text-5xl font-light italic text-nocta-cream leading-tight mb-8">
              Présents pour vous,<br/>
              <em class="not-italic font-extralight">invisibles si besoin.</em>
            </h2>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-cream/60 mb-6">
              NOCTA Private, c'est l'art de recevoir chez soi sans en porter le poids. Nous prenons en charge l'intégralité de l'expérience — conception du menu, mise en place, service, rangement — pour que vous soyez entièrement présent à vos invités.
            </p>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-cream/60">
              Chaque dîner est pensé comme un événement unique, à votre image. Produits de saison sélectionnés avec soin, cuisine préparée sur place, service discret et attentif. L'excellence, sans l'ostentation.
            </p>
          </div>

          <div class="reveal" style="transition-delay: 0.15s">
            <div class="overflow-hidden" style="max-width: 360px; aspect-ratio: 4/5;">
              <img src="/images/nocta-bouche-private.jpg" alt="NOCTA Private — Mise en bouche" class="w-full h-full object-cover object-center" />
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Formats -->
    <section class="bg-nocta-cream py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">

        <div class="mb-16 reveal">
          <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-4">Nos formats</p>
          <h2 class="font-serif text-4xl lg:text-5xl font-light italic text-nocta-black leading-tight">
            Ce que nous proposons.
          </h2>
        </div>

        <div>
          <div class="border-t border-nocta-black/10 py-7 flex items-center gap-8 reveal" style="transition-delay: 0.05s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0">01</span>
            <span class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Dîner privé</span>
          </div>
          <div class="border-t border-nocta-black/10 py-7 flex items-center gap-8 reveal" style="transition-delay: 0.1s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0">02</span>
            <span class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Anniversaire d'exception</span>
          </div>
          <div class="border-t border-nocta-black/10 py-7 flex items-center gap-8 reveal" style="transition-delay: 0.15s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0">03</span>
            <span class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Célébration familiale</span>
          </div>
          <div class="border-t border-b border-nocta-black/10 py-7 flex items-center gap-8 reveal" style="transition-delay: 0.2s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0">04</span>
            <span class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Chef à domicile</span>
          </div>
        </div>

      </div>
    </section>

    <!-- CTA -->
    <section class="bg-nocta-black py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center reveal">
        <h2 class="font-serif text-2xl md:text-4xl lg:text-6xl font-light italic text-nocta-cream leading-tight mb-10">
          Parlons de votre événement.
        </h2>
        <a href="/contact" class="inline-flex items-center font-sans text-sm font-light tracking-widest uppercase bg-nocta-cream text-nocta-black px-8 py-3 hover:bg-white transition-all duration-300">
          Demander un devis
        </a>
      </div>
    </section>

  </main>

  <Footer />

</Layout>
