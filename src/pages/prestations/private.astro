---
import Layout from '../../layouts/layout.astro';
import Header from '../../components/header.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import LogoSlider from '../../components/LogoSlider.astro';
import privateHeroSrc from '../../assets/images/private-hero.webp?url';
---

<Layout
  title="NOCTA Private — Chef à domicile & Dîners privés à Paris | NOCTA"
  description="Chef privé à domicile à Paris et en Île-de-France. NOCTA Private organise vos dîners intimes, anniversaires d'exception et célébrations familiales avec un chef formé en cuisine étoilée et un sommelier."
>
  <Header />

  <main>

    <!-- Hero -->
    <section class="relative min-h-[50vh] lg:min-h-[70vh] flex flex-col justify-end bg-nocta-black overflow-hidden">
      <div class="absolute inset-0">
        <img
          src={privateHeroSrc}
          alt="Chef privé à domicile Paris — dîner gastronomique sur-mesure NOCTA Private"
          width="3024"
          height="4032"
          class="w-full h-full object-cover"
          style="object-position: center 70%;"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-black/30"></div>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-20 lg:pb-28 w-full">
        <a href="/prestations" class="inline-flex items-center gap-3 font-sans text-xs tracking-widest uppercase text-nocta-cream/60 hover:text-nocta-cream transition-colors duration-200 mb-12 animate-fade-up" style="animation-delay: 0.1s; opacity: 0;">
          <span class="w-6 h-px bg-current inline-block"></span>
          Nos Prestations
        </a>
        <p class="font-sans text-xs font-light tracking-[0.4em] uppercase text-nocta-cream/60 mb-6 animate-fade-up" style="animation-delay: 0.2s; opacity: 0;">
          01
        </p>
        <h1 class="font-serif text-3xl md:text-5xl lg:text-7xl xl:text-8xl font-light italic text-nocta-cream leading-[1.05] mb-6 animate-fade-up" style="animation-delay: 0.35s; opacity: 0;">
          NOCTA Private
        </h1>
        <p class="font-sans text-base lg:text-lg font-light text-nocta-cream/70 animate-fade-up" style="animation-delay: 0.5s; opacity: 0;">
          Recevoir chez soi, sans s'en occuper.
        </p>
      </div>
    </section>

    <!-- About -->
    <section class="bg-nocta-black py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">

          <div class="reveal">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-cream/40 mb-4">Notre approche</p>
            <h2 class="font-serif text-2xl md:text-4xl lg:text-5xl font-light italic text-nocta-cream leading-tight mb-8">
              Présents pour vous,<br/>
              <em class="not-italic font-extralight">invisibles si besoin.</em>
            </h2>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-cream/60 mb-6">
              NOCTA Private, c'est recevoir chez soi sans en porter le poids. Nous prenons en charge l'intégralité - conception du menu, mise en place, service, rangement - pour que vous soyez pleinement présent à vos invités, pas à votre cuisine.
            </p>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-cream/60">
              Chaque dîner est construit selon vos envies : produits de saison, cuisine préparée sur place, service discret et attentif. Pas de formule standard - chaque table est différente.
            </p>
          </div>

          <div class="reveal" style="transition-delay: 0.15s">
            <div class="overflow-hidden" style="max-width: 360px; aspect-ratio: 4/5;">
              <img src="/images/nocta-bouche-private.webp" alt="Dressage d'assiette dîner privé — chef à domicile Paris Île-de-France" width="2400" height="2537" loading="lazy" class="w-full h-full object-cover object-center" />
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Formats -->
    <section class="bg-nocta-cream py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">

        <div class="mb-16 reveal">
          <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-4">Nos formats</p>
          <h2 class="font-serif text-4xl lg:text-5xl font-light italic text-nocta-black leading-tight">
            Ce que nous proposons.
          </h2>
        </div>

        <div>
          <div class="border-t border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.05s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">01</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Dîner privé</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">De 6 à 20 personnes, à domicile ou en lieu privatisé.</p>
            </div>
          </div>
          <div class="border-t border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.1s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">02</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Anniversaire d'exception</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">Un repas pensé autour de vous, de vos invités, de ce que vous aimez.</p>
            </div>
          </div>
          <div class="border-t border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.15s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">03</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Célébration familiale</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">Retrouvailles, fêtes de fin d'année, moments qui comptent.</p>
            </div>
          </div>
          <div class="border-t border-b border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.2s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">04</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Chef à domicile</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">Hugo cuisine chez vous. Une expérience directe, sans intermédiaire.</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- Tarifs -->
    <section class="bg-nocta-cream pb-24 lg:pb-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="border-t border-nocta-black/10 pt-16 reveal">
          <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-4">Tarifs indicatifs</p>
          <p class="font-serif text-2xl md:text-3xl font-light italic text-nocta-black leading-snug mb-6">
            À partir de 55 € par personne.
          </p>
          <p class="font-sans text-sm font-light text-nocta-grey leading-relaxed max-w-2xl">
            Chef et service compris. Minimum de commande : 500 € HT. Chaque menu est conçu sur-mesure — le tarif exact dépend du nombre de convives, du menu et des produits choisis.
          </p>
        </div>
      </div>
    </section>

    <!-- Preuve sociale : logos clients -->
    <LogoSlider />

    {/*
      TODO Enzo : ajouter ici un témoignage client réel pour /prestations/private (1 par page).
      Format suggéré :
        "Citation courte (1-2 phrases concrètes)."
        — Prénom Nom, Poste (ou contexte sobre)
      Candidat évident : Thomas Cussac (déjà cité sur la home, évènement privé).
      Ne PAS inventer de poste/employeur — la home utilise simplement "Événement privé".
    */}

    <!-- Journal -->
    <section class="bg-nocta-black py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="mb-12 reveal">
          <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-cream/40 mb-4">À lire</p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <a href="/journal/chef-prive-domicile-paris" class="group block border border-nocta-cream/10 p-8 hover:border-nocta-cream/30 transition-all duration-300 reveal" style="transition-delay: 0.1s">
            <p class="font-sans text-xs tracking-widest uppercase text-nocta-cream/40 mb-3">Guide</p>
            <p class="font-serif text-xl lg:text-2xl font-light italic text-nocta-cream group-hover:text-white transition-colors">Chef privé à domicile à Paris : comment ça marche ?</p>
          </a>
          <a href="/journal/budget-traiteur-paris" class="group block border border-nocta-cream/10 p-8 hover:border-nocta-cream/30 transition-all duration-300 reveal" style="transition-delay: 0.2s">
            <p class="font-sans text-xs tracking-widest uppercase text-nocta-cream/40 mb-3">Guide</p>
            <p class="font-serif text-xl lg:text-2xl font-light italic text-nocta-cream group-hover:text-white transition-colors">Quel budget prévoir pour un traiteur à Paris en 2026 ?</p>
          </a>
        </div>
      </div>
    </section>

    <CallToAction />

  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "NOCTA Private — Chef privé à domicile à Paris",
    "description": "Dîners privés à domicile, anniversaires et célébrations avec un chef formé en cuisine étoilée et un sommelier. Paris et Île-de-France.",
    "provider": {"@type": "Organization", "name": "NOCTA Catering", "url": "https://www.noctaparis.fr"},
    "areaServed": [{"@type": "City", "name": "Paris"}, {"@type": "AdministrativeArea", "name": "Île-de-France"}],
    "serviceType": "Chef privé à domicile",
    "offers": {"@type": "Offer", "priceCurrency": "EUR", "price": "55", "priceSpecification": {"@type": "UnitPriceSpecification", "price": "55", "priceCurrency": "EUR", "unitText": "par personne", "description": "À partir de 55 € par personne, chef et service compris. Minimum de commande : 500 € HT."}}
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://www.noctaparis.fr/"},
      {"@type": "ListItem", "position": 2, "name": "Prestations", "item": "https://www.noctaparis.fr/prestations"},
      {"@type": "ListItem", "position": 3, "name": "NOCTA Private", "item": "https://www.noctaparis.fr/prestations/private"}
    ]
  })} />

</Layout>
