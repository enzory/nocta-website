---
import Layout from '../../layouts/layout.astro';
import Header from '../../components/header.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
---

<Layout
  title="NOCTA Signature — Expériences Gastronomiques Immersives à Paris | NOCTA"
  description="Expériences gastronomiques sur-mesure à Paris. NOCTA Signature compose des dîners immersifs alliant cuisine, sommellerie et scénographie — pour des événements uniques en Île-de-France."
>
  <Header />

  <main>

    <!-- Hero -->
    <section class="relative min-h-[50vh] lg:min-h-[70vh] flex flex-col justify-end bg-nocta-black overflow-hidden">
      <div class="absolute inset-0">
        <img
          src="/images/sainttropez-petitdejeuner-private.webp"
          alt="Expérience culinaire immersive Paris — dîner de collection NOCTA Signature"
          width="1800"
          height="2400"
          class="w-full h-full object-cover"
          style="object-position: center 30%;"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-black/50"></div>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-20 lg:pb-28 w-full">
        <a href="/prestations" class="inline-flex items-center gap-3 font-sans text-xs tracking-widest uppercase text-nocta-cream/60 hover:text-nocta-cream transition-colors duration-200 mb-12 animate-fade-up" style="animation-delay: 0.1s; opacity: 0;">
          <span class="w-6 h-px bg-current inline-block"></span>
          Nos Prestations
        </a>
        <p class="font-sans text-xs font-light tracking-[0.4em] uppercase text-nocta-cream/60 mb-6 animate-fade-up" style="animation-delay: 0.2s; opacity: 0;">
          03
        </p>
        <h1 class="font-serif text-3xl md:text-5xl lg:text-7xl xl:text-8xl font-light italic text-nocta-cream leading-[1.05] mb-6 animate-fade-up" style="animation-delay: 0.35s; opacity: 0;">
          NOCTA Signature
        </h1>
        <p class="font-sans text-base lg:text-lg font-light text-nocta-cream/70 animate-fade-up" style="animation-delay: 0.5s; opacity: 0;">
          Notre format le plus libre.
        </p>
      </div>
    </section>

    <!-- About -->
    <section class="bg-nocta-black py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">

          <div class="reveal">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-cream/40 mb-4">Notre approche</p>
            <h2 class="font-serif text-2xl md:text-4xl lg:text-5xl font-light italic text-nocta-cream leading-tight">
              Une expérience construite de bout en bout.
            </h2>
          </div>

          <div class="reveal" style="transition-delay: 0.15s">
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-cream/60 mb-6">
              NOCTA Signature est le format où nous avons le plus de latitude. Cuisine, vins, scénographie, rythme du service - tout est pensé ensemble pour former une expérience cohérente, pas une succession de prestations.
            </p>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-cream/60">
              Nous travaillons en collaboration directe avec nos clients pour définir un concept sur-mesure. Le point de départ peut être n'importe quoi : un lieu, un vin, une saison, une occasion. Nous construisons le reste.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- Approach image -->
    <div class="w-full h-[400px] overflow-hidden">
      <img src="/images/salon-signature.webp" alt="Dîner gastronomique sur-mesure — scénographie et sommellerie Paris" width="1800" height="2400" loading="lazy" class="w-full h-full object-cover" />
    </div>

    <!-- Formats -->
    <section class="bg-nocta-cream py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">

        <div class="mb-16 reveal">
          <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-4">Nos formats</p>
          <h2 class="font-serif text-2xl md:text-4xl lg:text-5xl font-light italic text-nocta-black leading-tight">
            Ce que nous proposons.
          </h2>
        </div>

        <div>
          <div class="border-t border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.05s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">01</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Dîner immersif</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">Un repas pensé comme un parcours - chaque plat a sa place dans une progression.</p>
            </div>
          </div>
          <div class="border-t border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.1s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">02</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Expérience œnologique</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">La sélection de vins est au cœur. La cuisine l'accompagne.</p>
            </div>
          </div>
          <div class="border-t border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.15s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">03</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Soirée thématique</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">Un fil conducteur - une région, un producteur, une saison - décliné sur toute la table.</p>
            </div>
          </div>
          <div class="border-t border-b border-nocta-black/10 py-7 flex items-start gap-8 reveal" style="transition-delay: 0.2s">
            <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey w-8 shrink-0 pt-2">04</span>
            <div>
              <h3 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black">Dîner de collection</h3>
              <p class="font-sans text-sm font-light text-nocta-grey mt-2">Autour d'une bouteille rare ou d'un accord particulier. Pour les amateurs sérieux.</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <CallToAction />

  </main>

  <Footer />

</Layout>
