---
import Layout from '../layouts/layout.astro';
import Header from '../components/header.astro';
import Footer from '../components/Footer.astro';
import LogoSlider from '../components/LogoSlider.astro';
---

<Layout
  title="NOCTA — Traiteur, Chef privé & Sommelier à Paris"
  description="NOCTA conçoit des expériences culinaires sur-mesure à Paris et en Île-de-France. Traiteur haut de gamme, chef privé et sommelier pour dîners privés, événements corporate et réceptions d'exception."
>
  <Header />

  <main>

    <!-- HERO -->
    <section id="hero" class="relative min-h-screen flex flex-col justify-end bg-nocta-black overflow-hidden">

      <!-- PREMIÈRE IMAGE : élément statique, LCP cible — eager + high priority, hors carousel JS -->
      <img
        id="hero-lcp-image"
        src="/images/nocta-assiette-hero1-800w.webp"
        srcset="
          /images/nocta-assiette-hero1-400w.webp   400w,
          /images/nocta-assiette-hero1-800w.webp   800w,
          /images/nocta-assiette-hero1-1200w.webp 1200w,
          /images/nocta-assiette-hero1.webp       2400w
        "
        sizes="100vw"
        alt="Assiette gastronomique chef privé Paris — dressage NOCTA"
        width="2400"
        height="3200"
        loading="eager"
        fetchpriority="high"
        class="absolute inset-0 w-full h-full object-cover"
      />

      <!-- SLIDES 2 & 3 : chargées en lazy, animées par JS après le premier intervalle -->
      <div id="carousel" class="absolute inset-0 h-full" aria-hidden="true">
        <img
          id="carousel-slide-1"
          src="/images/nocta-pancetta-hero4-800w.webp"
          srcset="
            /images/nocta-pancetta-hero4-800w.webp  800w,
            /images/nocta-pancetta-hero4-1200w.webp 1200w,
            /images/nocta-pancetta-hero4.webp       2400w
          "
          sizes="100vw"
          alt="Pancetta croustillante dressée par le chef — catering haut de gamme Paris"
          width="800"
          height="1067"
          loading="lazy"
          fetchpriority="auto"
          class="absolute inset-0 w-full h-full object-cover"
          style="opacity: 0; object-position: center 60%;"
        />
        <img
          id="carousel-slide-2"
          src="/images/nocta-fleur-courgette-hero3-800w.webp"
          srcset="
            /images/nocta-fleur-courgette-hero3-800w.webp  800w,
            /images/nocta-fleur-courgette-hero3-1200w.webp 1200w,
            /images/nocta-fleur-courgette-hero3.webp       2400w
          "
          sizes="100vw"
          alt="Fleur de courgette farcie — chef privé traiteur Paris Île-de-France"
          width="800"
          height="1067"
          loading="lazy"
          fetchpriority="auto"
          class="absolute inset-0 w-full h-full object-cover"
          style="opacity: 0;"
        />
      </div>

      <!-- Gradient overlay — au-dessus des deux couches d'images -->
      <div class="absolute inset-0 bg-gradient-to-t from-nocta-black/80 via-nocta-black/20 to-transparent pointer-events-none z-[1]"></div>

      <!-- Prev arrow -->
      <button
        id="carousel-prev"
        class="carousel-arrow absolute left-4 lg:left-8 top-1/2 -translate-y-1/2 z-20 w-12 h-12 hidden md:flex items-center justify-center opacity-0 transition-opacity duration-300"
        aria-label="Image précédente"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>

      <!-- Next arrow -->
      <button
        id="carousel-next"
        class="carousel-arrow absolute right-4 lg:right-8 top-1/2 -translate-y-1/2 z-20 w-12 h-12 hidden md:flex items-center justify-center opacity-0 transition-opacity duration-300"
        aria-label="Image suivante"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>

      <!-- Hero text -->
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 pb-20 lg:pb-28">
        <p class="font-sans text-xs font-light tracking-[0.4em] uppercase text-nocta-cream/60 mb-6 animate-fade-up" style="animation-delay: 0.2s; opacity: 0;">
          Paris, Île-de-France & ailleurs
        </p>
        <h1 class="font-serif text-3xl md:text-5xl lg:text-7xl xl:text-8xl font-light italic text-nocta-cream leading-[1.05] max-w-3xl mb-8 animate-fade-up" style="animation-delay: 0.4s; opacity: 0;">
          L'art de recevoir,<br/>
          <em class="not-italic font-extralight">sans compromis.</em>
        </h1>
        <p class="font-sans text-base lg:text-lg font-light text-nocta-cream/70 max-w-xl leading-relaxed mb-12 animate-fade-up" style="animation-delay: 0.6s; opacity: 0;">
          NOCTA conçoit des expériences culinaires sur-mesure pour les entreprises et les particuliers exigeants - à Paris, en Île-de-France et au-delà.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 animate-fade-up" style="animation-delay: 0.8s; opacity: 0;">
          <a href="/contact" class="inline-flex items-center justify-center font-sans text-sm font-light tracking-widest uppercase bg-nocta-cream text-nocta-black px-8 py-3 transition-all duration-300 hover:bg-white">
            Demander un devis
          </a>
          <a href="/prestations" class="inline-flex items-center justify-center font-sans text-sm font-light tracking-widest uppercase border border-nocta-cream/50 text-nocta-cream px-8 py-3 transition-all duration-300 hover:border-nocta-cream">
            Explorer nos prestations
          </a>
        </div>
      </div>

      <!-- Dot indicators : 3 statiques (image LCP + 2 slides carousel) -->
      <div id="carousel-dots" class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex items-center gap-2.5" aria-hidden="true">
        <button class="carousel-dot w-3 h-3 rounded-full bg-white/40 transition-all duration-300" data-index="0" aria-label="Slide 1"></button>
        <button class="carousel-dot w-3 h-3 rounded-full bg-white/40 transition-all duration-300" data-index="1" aria-label="Slide 2"></button>
        <button class="carousel-dot w-3 h-3 rounded-full bg-white/40 transition-all duration-300" data-index="2" aria-label="Slide 3"></button>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 right-6 lg:right-12 hidden md:flex flex-col items-center gap-2 animate-fade-in" style="animation-delay: 1.2s; opacity: 0;" aria-hidden="true">
        <span class="font-sans text-xs tracking-widest uppercase text-nocta-cream/40">Scroll</span>
        <div class="w-px h-12 bg-nocta-cream/20 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1/2 bg-nocta-cream/60 animate-bounce"></div>
        </div>
      </div>
    </section>

    <!-- FORMATS -->
    <section class="bg-nocta-black py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-12 reveal">
          <div>
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-cream/40 mb-4">Nos formats</p>
            <h2 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-cream leading-tight">
              Trois formats, une seule exigence.
            </h2>
          </div>
          <a href="/prestations" class="mt-8 lg:mt-0 font-sans text-sm font-light tracking-widest uppercase text-nocta-cream/60 hover:text-nocta-cream transition-colors duration-300 flex items-center gap-3">
            Voir toutes les prestations
            <span class="w-8 h-px bg-current inline-block"></span>
          </a>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-px bg-nocta-cream/10">
          <a href="/prestations/private" class="group block bg-nocta-black p-10 hover:bg-nocta-cream/5 transition-all duration-500 reveal" style="transition-delay: 0.1s">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-cream/40 mb-8">01</p>
            <h3 class="font-serif text-3xl font-light italic text-nocta-cream mb-4 group-hover:text-white transition-colors">NOCTA Private</h3>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-cream/50 mb-10">
              Dîners à domicile, anniversaires, célébrations familiales. Nous prenons en charge l'intégralité - pour que vous soyez présent à vos invités, pas à votre cuisine.
            </p>
            <span class="font-sans text-xs tracking-widest uppercase text-nocta-cream/30 group-hover:text-nocta-cream/60 transition-colors flex items-center gap-3">
              Découvrir
              <span class="w-6 h-px bg-current inline-block group-hover:w-10 transition-all duration-300"></span>
            </span>
          </a>
          <a href="/prestations/corporate" class="group block bg-nocta-black p-10 hover:bg-nocta-cream/5 transition-all duration-500 reveal" style="transition-delay: 0.2s">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-cream/40 mb-8">02</p>
            <h3 class="font-serif text-3xl font-light italic text-nocta-cream mb-4 group-hover:text-white transition-colors">NOCTA Corporate</h3>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-cream/50 mb-10">
              Cocktails de lancement, dîners de gala, comités de direction. Une gastronomie à la hauteur de l'image que vous souhaitez donner.
            </p>
            <span class="font-sans text-xs tracking-widest uppercase text-nocta-cream/30 group-hover:text-nocta-cream/60 transition-colors flex items-center gap-3">
              Découvrir
              <span class="w-6 h-px bg-current inline-block group-hover:w-10 transition-all duration-300"></span>
            </span>
          </a>
          <a href="/prestations/signature" class="group block bg-nocta-black p-10 hover:bg-nocta-cream/5 transition-all duration-500 reveal" style="transition-delay: 0.3s">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-cream/40 mb-8">03</p>
            <h3 class="font-serif text-3xl font-light italic text-nocta-cream mb-4 group-hover:text-white transition-colors">NOCTA Signature</h3>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-cream/50 mb-10">
              Un format sur-mesure où cuisine, vins et scénographie composent une expérience cohérente de bout en bout.
            </p>
            <span class="font-sans text-xs tracking-widest uppercase text-nocta-cream/30 group-hover:text-nocta-cream/60 transition-colors flex items-center gap-3">
              Découvrir
              <span class="w-6 h-px bg-current inline-block group-hover:w-10 transition-all duration-300"></span>
            </span>
          </a>
        </div>
      </div>
    </section>

    <LogoSlider />

    <!-- PHOTO GALLERY -->
    <section class="bg-nocta-cream py-24 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">

        <div class="mb-16 reveal">
          <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-4">Nos réalisations</p>
          <h2 class="font-serif text-2xl md:text-4xl lg:text-5xl font-light italic text-nocta-black leading-tight">
            Chaque événement,<br/>une signature.
          </h2>
          <p class="font-sans text-sm font-light text-nocta-grey mt-4">Quelques tables que nous avons dressées.</p>
        </div>

        <!-- 2-row grid: 2 top + 3 bottom -->
        <div class="grid grid-cols-2 gap-3 lg:gap-4 mb-3 lg:mb-4">
          <div class="overflow-hidden reveal aspect-square" style="transition-delay: 0.05s">
            <a href="/images/nocta-assiette-poireau.webp" class="glightbox block w-full h-full" data-gallery="nocta">
              <img
                src="/images/nocta-assiette-poireau-800w.webp"
                srcset="/images/nocta-assiette-poireau-400w.webp 400w, /images/nocta-assiette-poireau-800w.webp 800w, /images/nocta-assiette-poireau.webp 1355w"
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt="Assiette poireau vinaigrette — dîner privé sur-mesure Paris"
                width="800"
                height="945"
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-105"
              />
            </a>
          </div>
          <div class="overflow-hidden reveal aspect-square" style="transition-delay: 0.1s">
            <a href="/images/nocta-celeri-marche.webp" class="glightbox block w-full h-full" data-gallery="nocta">
              <img
                src="/images/nocta-celeri-marche-800w.webp"
                srcset="/images/nocta-celeri-marche-400w.webp 400w, /images/nocta-celeri-marche-800w.webp 800w, /images/nocta-celeri-marche.webp 2400w"
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt="Céleri du marché préparé en cuisine — traiteur événementiel Paris"
                width="800"
                height="1067"
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-105"
              />
            </a>
          </div>
        </div>
        <div class="grid grid-cols-3 gap-3 lg:gap-4">
          <div class="overflow-hidden reveal aspect-square" style="transition-delay: 0.15s">
            <a href="/images/nocta-madeleine-canele.webp" class="glightbox block w-full h-full" data-gallery="nocta">
              <img
                src="/images/nocta-madeleine-canele-800w.webp"
                srcset="/images/nocta-madeleine-canele-400w.webp 400w, /images/nocta-madeleine-canele-800w.webp 800w, /images/nocta-madeleine-canele.webp 1200w"
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt="Madeleines et canelés maison — cocktail traiteur Paris"
                width="800"
                height="673"
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-105"
              />
            </a>
          </div>
          <div class="overflow-hidden reveal aspect-square" style="transition-delay: 0.2s">
            <a href="/images/nocta-assiette-tomate.webp" class="glightbox block w-full h-full" data-gallery="nocta">
              <img
                src="/images/nocta-assiette-tomate-800w.webp"
                srcset="/images/nocta-assiette-tomate-400w.webp 400w, /images/nocta-assiette-tomate-800w.webp 800w, /images/nocta-assiette-tomate.webp 2400w"
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt="Assiette tomate ancienne — catering gastronomique Paris"
                width="800"
                height="1067"
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-105"
              />
            </a>
          </div>
          <div class="overflow-hidden reveal aspect-square" style="transition-delay: 0.25s">
            <a href="/images/sainttropez-petitdejeuner-private.webp" class="glightbox block w-full h-full" data-gallery="nocta">
              <img
                src="/images/sainttropez-petitdejeuner-private-800w.webp"
                srcset="/images/sainttropez-petitdejeuner-private-400w.webp 400w, /images/sainttropez-petitdejeuner-private-800w.webp 800w, /images/sainttropez-petitdejeuner-private.webp 1800w"
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt="Petit-déjeuner de luxe à Saint-Tropez — NOCTA Private chef privé"
                width="800"
                height="1067"
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 ease-out hover:scale-105"
              />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- APPROCHE -->
    <section class="bg-nocta-cream py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="max-w-2xl mb-14 reveal">
          <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-4">Notre approche</p>
          <h2 class="font-serif text-3xl lg:text-4xl font-light italic text-nocta-black leading-tight">
            Gastronomie, service, sommellerie.
          </h2>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-8">
          <div class="reveal" style="transition-delay: 0.1s">
            <div class="w-8 h-px bg-nocta-black mb-8"></div>
            <h3 class="font-serif text-2xl font-light italic text-nocta-black mb-4">La cuisine</h3>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey">
              Hugo et son équipe sont formés dans les cuisines étoilées. Chaque menu est construit avec soin, chaque produit sélectionné pour ce qu'il est - pas pour ce qu'il représente.
            </p>
          </div>
          <div class="reveal" style="transition-delay: 0.2s">
            <div class="w-8 h-px bg-nocta-black mb-8"></div>
            <h3 class="font-serif text-2xl font-light italic text-nocta-black mb-4">Le service</h3>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey">
              Un bon repas se joue autant en salle qu'en cuisine. Gestuelle, rythme, attention discrète : nous maîtrisons ces codes depuis le premier jour.
            </p>
          </div>
          <div class="reveal" style="transition-delay: 0.3s">
            <div class="w-8 h-px bg-nocta-black mb-8"></div>
            <h3 class="font-serif text-2xl font-light italic text-nocta-black mb-4">La sommellerie</h3>
            <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey">
              Enzo compose chaque sélection de vins en fonction du menu, du moment et des personnes autour de la table. Pas une liste - une ligne directrice.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-nocta-cream py-24 lg:py-36 border-t border-nocta-black/10">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center reveal">
        <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-6">Votre prochain événement</p>
        <h2 class="font-serif text-2xl md:text-4xl lg:text-6xl font-light italic text-nocta-black leading-tight mb-10 max-w-2xl mx-auto">
          Parlons de ce que vous avez en tête.
        </h2>
        <a href="/contact" class="inline-flex items-center font-sans text-sm font-light tracking-widest uppercase bg-nocta-black text-nocta-cream px-8 py-3 hover:bg-nocta-black/80 transition-all duration-300">
          Demander un devis
        </a>
      </div>
    </section>

  </main>

  <Footer />

</Layout>

<style>
  /* Show arrows when hero is hovered */
  #hero:hover .carousel-arrow {
    opacity: 1;
  }
</style>

<script>
  // Carousel avec image LCP statique hors du carousel JS
  // Position 0 = #hero-lcp-image (dans le DOM au chargement, eager, fetchpriority=high)
  // Position 1 = #carousel-slide-1 (pancetta, lazy)
  // Position 2 = #carousel-slide-2 (fleur-courgette, lazy)
  //
  // RÈGLE LCP : heroLcp ne doit JAMAIS avoir son opacity modifié par JS.
  // Chrome retire un élément des candidats LCP dès que opacity passe à 0.
  // Solution : seuls slide1 et slide2 s'animent. heroLcp reste toujours à opacity:1
  // (visible en dessous des slides quand celles-ci sont à opacity:0).

  const heroLcp = document.getElementById('hero-lcp-image') as HTMLImageElement | null;
  const slide1  = document.getElementById('carousel-slide-1') as HTMLImageElement | null;
  const slide2  = document.getElementById('carousel-slide-2') as HTMLImageElement | null;
  const dots    = document.querySelectorAll<HTMLElement>('.carousel-dot');
  const hero    = document.getElementById('hero');

  if (!heroLcp || !slide1 || !slide2) throw new Error('Hero elements not found');

  const FADE = 'opacity 600ms ease-in-out';

  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    // Mettre à jour les dots
    dots[current].style.backgroundColor = 'rgba(255,255,255,0.4)';
    dots[current].style.transform       = 'scale(1)';

    current = ((index % 3) + 3) % 3;

    dots[current].style.backgroundColor = 'rgba(255,255,255,0.9)';
    dots[current].style.transform       = 'scale(1.3)';

    // Animer UNIQUEMENT les slides carousel — heroLcp n'est jamais touché
    // heroLcp reste à opacity:1 en permanence (LCP toujours valide)
    slide1.style.transition = FADE;
    slide2.style.transition = FADE;

    if (current === 0) {
      // Position heroLcp : masquer les deux slides → heroLcp visible dessous
      slide1.style.opacity = '0';
      slide2.style.opacity = '0';
    } else if (current === 1) {
      // Position slide1 : slide1 recouvre heroLcp
      slide1.style.opacity = '1';
      slide2.style.opacity = '0';
    } else {
      // Position slide2 : slide2 recouvre heroLcp
      slide1.style.opacity = '0';
      slide2.style.opacity = '1';
    }
  }

  // Init : activer le premier point sans animer (LCP image déjà visible via CSS à opacity:1)
  dots[0].style.backgroundColor = 'rgba(255,255,255,0.9)';
  dots[0].style.transform       = 'scale(1.3)';

  function startTimer() {
    timer = setInterval(() => goTo(current + 1), 5000);
  }

  function stopTimer() {
    clearInterval(timer);
  }

  // Auto-play
  startTimer();

  // Pause on hover
  hero?.addEventListener('mouseenter', stopTimer);
  hero?.addEventListener('mouseleave', startTimer);

  // Arrow controls
  document.getElementById('carousel-prev')?.addEventListener('click', () => {
    stopTimer();
    goTo(current - 1);
    startTimer();
  });

  document.getElementById('carousel-next')?.addEventListener('click', () => {
    stopTimer();
    goTo(current + 1);
    startTimer();
  });

  // Dot controls
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      stopTimer();
      goTo(i);
      startTimer();
    });
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (document.querySelector('.glightbox')) {
      // GLightbox chargé en defer — on attend qu'il soit disponible
      const initGlightbox = () => {
        if (typeof GLightbox !== 'undefined') {
          GLightbox({ touchNavigation: true, loop: false });
        } else {
          requestAnimationFrame(initGlightbox);
        }
      };
      initGlightbox();
    }
  });
</script>
