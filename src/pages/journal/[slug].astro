---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/layout.astro';
import Header from '../../components/header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const articles = await getCollection('journal', ({ data }) => !data.draft);
  return articles.map(article => ({
    params: { slug: article.id.replace(/\.md$/, '') },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();

const formattedDate = article.data.date.toLocaleDateString('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Maillage interne : 3 autres lectures, drafts exclus, triées par date desc
const allJournal = await getCollection('journal');
const otherArticles = allJournal
  .filter((a) => a.slug !== article.slug && !a.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title={`${article.data.title} — NOCTA`} description={article.data.description}>
  <Header />

  <main>

    <!-- HERO ARTICLE -->
    <section class="bg-nocta-black pt-40 pb-16">
      <div class="max-w-3xl mx-auto px-6 lg:px-12">
        <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-cream/40 mb-6 animate-fade-up" style="animation-delay: 0.1s; opacity: 0;">
          {article.data.category} — {article.data.readTime} min de lecture
        </p>
        <h1 class="font-serif text-3xl md:text-5xl font-light italic text-nocta-cream leading-[1.1] mb-8 animate-fade-up" style="animation-delay: 0.3s; opacity: 0;">
          {article.data.title}
        </h1>
        <p class="font-sans text-sm font-light text-nocta-cream/50 animate-fade-up" style="animation-delay: 0.5s; opacity: 0;">
          {formattedDate}
        </p>
      </div>
    </section>

    <!-- CONTENU ARTICLE -->
    <section class="bg-nocta-cream py-16 lg:py-24">
      <div class="max-w-3xl mx-auto px-6 lg:px-12">
        <div class="prose prose-nocta font-sans font-light leading-relaxed text-nocta-black/80">
          <Content />
        </div>

        <!-- RETOUR JOURNAL -->
        <div class="mt-16 pt-12 border-t border-nocta-black/10">
          <a href="/journal" class="inline-flex items-center gap-3 font-sans text-xs tracking-widest uppercase text-nocta-black/40 hover:text-nocta-black transition-colors duration-200">
            <span class="w-6 h-px bg-current inline-block"></span>
            Retour au Journal
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-nocta-black py-24">
      <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center">
        <h2 class="font-serif text-2xl md:text-4xl font-light italic text-nocta-cream mb-8">
          Parlons de votre événement.
        </h2>
        <a href="/contact" class="inline-flex items-center font-sans text-sm font-light tracking-widest uppercase bg-nocta-cream text-nocta-black px-8 py-3 hover:bg-white transition-all duration-300">
          Demander un devis
        </a>
      </div>
    </section>

    {otherArticles.length > 0 && (
      <section class="bg-nocta-cream py-16 lg:py-20 border-t border-nocta-black/10">
        <div class="max-w-3xl mx-auto px-6 lg:px-12">
          <h2 class="font-serif text-2xl md:text-3xl font-light italic text-nocta-black mb-8">
            Autres lectures
          </h2>
          <div class="related-grid">
            {otherArticles.map((a) => (
              <a href={`/journal/${a.id.replace(/\.md$/, '')}`} class="related-card">
                <span class="related-label">{a.data.category || 'Journal'}</span>
                <span class="related-title">{a.data.title}</span>
                <span class="related-date">
                  {a.data.date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' })}
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://www.noctaparis.fr/"},
      {"@type": "ListItem", "position": 2, "name": "Journal", "item": "https://www.noctaparis.fr/journal"},
      {"@type": "ListItem", "position": 3, "name": article.data.title, "item": `https://www.noctaparis.fr/journal/${article.id.replace(/\.md$/, '')}`}
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": article.data.title,
    "description": article.data.description,
    "datePublished": article.data.date.toISOString(),
    "image": {
      "@type": "ImageObject",
      "url": article.data.image ? `https://www.noctaparis.fr${article.data.image}` : "https://www.noctaparis.fr/images/og-image.jpeg",
      "width": 1200,
      "height": 630
    },
    "author": [
      {"@type": "Person", "name": "Hugo Vinatier", "url": "https://www.noctaparis.fr/maison"},
      {"@type": "Person", "name": "Enzo Ryon", "url": "https://www.noctaparis.fr/maison"}
    ],
    "publisher": {
      "@type": "Organization",
      "name": "NOCTA Catering",
      "url": "https://www.noctaparis.fr"
    },
    "mainEntityOfPage": `https://www.noctaparis.fr/journal/${article.id.replace(/\.md$/, '')}`
  })} />

</Layout>

<style>
  .prose-nocta h2 {
    font-family: var(--font-serif, 'Cormorant Garamond', serif);
    font-size: 1.5rem;
    font-weight: 300;
    font-style: italic;
    color: #0A0A0A;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .prose-nocta p {
    margin-bottom: 1.5rem;
    font-size: 1rem;
    line-height: 1.8;
  }

  .prose-nocta a {
    color: #0A0A0A;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose-nocta a:hover {
    opacity: 0.6;
  }

  .prose-nocta hr {
    border: none;
    border-top: 1px solid rgba(10,10,10,0.1);
    margin: 2rem 0;
  }

  .prose-nocta em {
    font-style: italic;
  }

  /* Maillage interne : autres lectures */
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }
  .related-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.5rem;
    border: 1px solid rgba(10, 10, 10, 0.1);
    background: transparent;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .related-card:hover {
    border-color: rgba(10, 10, 10, 0.3);
    background: rgba(255, 255, 255, 0.35);
  }
  .related-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(10, 10, 10, 0.45);
  }
  .related-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.2rem;
    font-weight: 400;
    line-height: 1.3;
    color: #0A0A0A;
  }
  .related-date {
    font-size: 0.8rem;
    color: rgba(10, 10, 10, 0.5);
    margin-top: auto;
  }
</style>
