---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout
  title="Journal — NOCTA"
  description="Le journal de NOCTA : gastronomie, service et art de recevoir."
>
  <Header />

  <main>

    <section class="bg-nocta-cream min-h-screen flex flex-col justify-center">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-40 pb-32">

        <p class="font-sans text-xs font-light tracking-[0.4em] uppercase text-nocta-grey mb-8 animate-fade-up" style="animation-delay: 0.2s; opacity: 0;">
          Journal
        </p>

        <h1 class="font-serif text-5xl lg:text-7xl xl:text-8xl font-light italic text-nocta-black leading-[1.05] max-w-3xl mb-8 animate-fade-up" style="animation-delay: 0.4s; opacity: 0;">
          Bientôt disponible.
        </h1>

        <p class="font-sans text-base lg:text-lg font-light text-nocta-grey max-w-xl leading-relaxed mb-16 animate-fade-up" style="animation-delay: 0.6s; opacity: 0;">
          Nous préparons des contenus sur la gastronomie, le service et l'art de recevoir.
        </p>

        <a
          href="/"
          class="inline-flex items-center gap-3 font-sans text-xs tracking-widest uppercase text-nocta-black/50 hover:text-nocta-black transition-colors duration-200 animate-fade-up"
          style="animation-delay: 0.8s; opacity: 0;"
        >
          <span class="w-6 h-px bg-current inline-block"></span>
          Retour à l'accueil
        </a>

      </div>
    </section>

  </main>

  <footer class="bg-nocta-black border-t border-nocta-cream/10 py-10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 flex flex-col lg:flex-row items-center justify-between gap-4">
      <span class="font-serif text-lg tracking-[0.3em] text-nocta-cream/60 uppercase">NOCTA</span>
      <p class="font-sans text-xs font-light text-nocta-cream/30 tracking-wide">
        © 2025 NOCTA — H+E Catering SARL · Paris & Île-de-France
      </p>
      <a href="/mentions-legales" class="font-sans text-xs font-light tracking-widest uppercase text-nocta-cream/30 hover:text-nocta-cream/60 transition-colors">
        Mentions légales
      </a>
    </div>
  </footer>

</Layout>
