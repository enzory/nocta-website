---
import { getCollection } from 'astro:content';
import Layout from '../layouts/layout.astro';
import Header from '../components/header.astro';
import Footer from '../components/Footer.astro';
import CallToAction from '../components/CallToAction.astro';

const articles = (await getCollection('journal'))
  .filter(a => !a.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Journal — Traiteur Paris, Sommellerie & Art de recevoir | NOCTA"
  description="Guides, retours d'expérience et coulisses : tout ce que NOCTA partage sur le métier de traiteur haut de gamme, la sommellerie et l'art de recevoir à Paris."
>
  <Header />

  <main>

    <!-- Hero -->
    <section class="bg-nocta-cream pt-40 pb-16 lg:pt-52 lg:pb-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <p class="font-sans text-xs font-light tracking-[0.4em] uppercase text-nocta-grey mb-6 animate-fade-up" style="animation-delay: 0.2s; opacity: 0;">
          Journal
        </p>
        <h1 class="font-serif text-3xl md:text-5xl lg:text-7xl font-light italic text-nocta-black leading-[1.05] max-w-3xl animate-fade-up" style="animation-delay: 0.4s; opacity: 0;">
          Gastronomie, service<br/>et art de recevoir.
        </h1>
      </div>
    </section>

    <!-- Liste articles -->
    <section class="bg-nocta-cream pb-28 lg:pb-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">

        {articles.map((article, i) => (
          <a
            href={`/journal/${article.id.replace(/\.md$/, '')}`}
            class="group flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 border-t border-nocta-black/10 py-10 hover:opacity-70 transition-opacity duration-200 reveal"
            style={`transition-delay: ${i * 0.05}s`}
          >
            <div class="flex items-start gap-6 lg:gap-10">
              <span class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey shrink-0 pt-1">
                {String(i + 1).padStart(2, '0')}
              </span>
              <div>
                <p class="font-sans text-xs tracking-widest uppercase text-nocta-grey mb-3">
                  {article.data.category}
                </p>
                <h2 class="font-serif text-2xl md:text-3xl lg:text-4xl font-light italic text-nocta-black leading-tight mb-3">
                  {article.data.title}
                </h2>
                <p class="font-sans text-sm font-light text-nocta-grey max-w-xl">
                  {article.data.description}
                </p>
              </div>
            </div>
            <div class="flex items-center gap-3 font-sans text-xs font-light tracking-widest uppercase text-nocta-black/40 group-hover:text-nocta-black transition-colors duration-200 shrink-0 lg:pt-1 pl-10 lg:pl-0">
              <span>{article.data.readTime} min</span>
              <span class="w-6 h-px bg-current inline-block group-hover:w-10 transition-all duration-300"></span>
            </div>
          </a>
        ))}

        <!-- Dernière border -->
        <div class="border-t border-nocta-black/10"></div>

      </div>
    </section>

    <!-- CTA conversion (audit 2026-04-27 : hub journal était cul-de-sac) -->
    <CallToAction subtitle="Autre chose en tête ?" heading="Parlons de votre événement." />

  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://www.noctaparis.fr/"},
      {"@type": "ListItem", "position": 2, "name": "Journal", "item": "https://www.noctaparis.fr/journal"}
    ]
  })} />

</Layout>
