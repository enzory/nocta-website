---
import Layout from '../layouts/layout.astro';
import Header from '../components/header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Journal — Gastronomie, Service & Art de recevoir | NOCTA Paris"
  description="Le journal de NOCTA : regards sur la gastronomie parisienne, le service haut de gamme, la sommellerie et l'art de recevoir. Par un traiteur et chef privé à Paris."
>
  <Header />

  <main>

    <section class="bg-nocta-cream min-h-screen flex flex-col justify-center">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-40 pb-32">

        <p class="font-sans text-xs font-light tracking-[0.4em] uppercase text-nocta-grey mb-8 animate-fade-up" style="animation-delay: 0.2s; opacity: 0;">
          Journal
        </p>

        <h1 class="font-serif text-3xl md:text-5xl lg:text-7xl xl:text-8xl font-light italic text-nocta-black leading-[1.05] max-w-3xl mb-8 animate-fade-up" style="animation-delay: 0.4s; opacity: 0;">
          Bientôt disponible.
        </h1>

        <p class="font-sans text-base lg:text-lg font-light text-nocta-grey max-w-xl leading-relaxed mb-16 animate-fade-up" style="animation-delay: 0.6s; opacity: 0;">
          Nous préparons des contenus sur la gastronomie, le service et l'art de recevoir.
        </p>

        <a
          href="/"
          class="inline-flex items-center gap-3 font-sans text-xs tracking-widest uppercase text-nocta-black/50 hover:text-nocta-black transition-colors duration-200 animate-fade-up"
          style="animation-delay: 0.8s; opacity: 0;"
        >
          <span class="w-6 h-px bg-current inline-block"></span>
          Retour à l'accueil
        </a>

      </div>
    </section>

  </main>

  <Footer />

</Layout>
