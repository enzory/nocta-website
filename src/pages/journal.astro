---
import { getCollection } from 'astro:content';
import Layout from '../layouts/layout.astro';
import Header from '../components/header.astro';
import Footer from '../components/Footer.astro';

const articles = await getCollection('journal', ({ data }) => !data.draft);
articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Journal — Gastronomie, Service & Art de recevoir | NOCTA Paris"
  description="Le journal de NOCTA : regards sur la gastronomie parisienne, le service haut de gamme, la sommellerie et l'art de recevoir. Par un traiteur et chef privé à Paris."
>
  <Header />

  <main>

    <section class="bg-nocta-cream min-h-screen">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-40 pb-32">

        <p class="font-sans text-xs font-light tracking-[0.4em] uppercase text-nocta-grey mb-8 animate-fade-up" style="animation-delay: 0.2s; opacity: 0;">
          Journal
        </p>

        <h1 class="font-serif text-3xl md:text-5xl lg:text-7xl font-light italic text-nocta-black leading-[1.05] max-w-3xl mb-20 animate-fade-up" style="animation-delay: 0.4s; opacity: 0;">
          Gastronomie, service,<br/>art de recevoir.
        </h1>

        <!-- LISTE DES ARTICLES -->
        {articles.length === 0 ? (
          <p class="font-sans text-sm font-light text-nocta-grey">Aucun article pour le moment.</p>
        ) : (
          <div class="divide-y divide-nocta-black/10">
            {articles.map((article) => {
              const formattedDate = article.data.date.toLocaleDateString('fr-FR', {
                day: 'numeric',
                month: 'long',
                year: 'numeric',
              });
              return (
                <a
                  href={`/journal/${article.id}`}
                  class="group flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 py-10 hover:opacity-70 transition-opacity duration-300 reveal"
                >
                  <div class="flex-1 max-w-2xl">
                    <p class="font-sans text-xs tracking-[0.3em] uppercase text-nocta-grey mb-3">
                      {article.data.category} — {article.data.readTime} min
                    </p>
                    <h2 class="font-serif text-2xl lg:text-3xl font-light italic text-nocta-black leading-snug mb-3 group-hover:text-nocta-black/70 transition-colors">
                      {article.data.title}
                    </h2>
                    <p class="font-sans text-sm font-light text-nocta-grey leading-relaxed">
                      {article.data.description}
                    </p>
                  </div>
                  <div class="lg:text-right shrink-0">
                    <p class="font-sans text-xs font-light text-nocta-grey/60">{formattedDate}</p>
                    <span class="font-sans text-xs tracking-widest uppercase text-nocta-black/30 group-hover:text-nocta-black/60 transition-colors flex lg:justify-end items-center gap-2 mt-4">
                      Lire
                      <span class="w-6 h-px bg-current inline-block group-hover:w-10 transition-all duration-300"></span>
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        )}

      </div>
    </section>

  </main>

  <Footer />

</Layout>
