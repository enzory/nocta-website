---
import Layout from '../layouts/layout.astro';
import Header from '../components/header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact — Demande de devis · NOCTA"
  description="Contactez NOCTA pour votre événement privé ou d'entreprise à Paris et en Île-de-France. Réponse sous 24 heures."
>
  <Header />

  <main>

    <!-- Hero -->
    <section class="bg-nocta-cream pt-40 pb-16 lg:pt-52 lg:pb-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <p class="font-sans text-xs font-light tracking-[0.4em] uppercase text-nocta-grey mb-6 animate-fade-up" style="animation-delay: 0.2s; opacity: 0;">
          Nous contacter
        </p>
        <h1 class="font-serif text-3xl md:text-5xl lg:text-7xl font-light italic text-nocta-black leading-[1.05] mb-6 animate-fade-up" style="animation-delay: 0.35s; opacity: 0;">
          Parlons de votre événement.
        </h1>
        <p class="font-sans text-base lg:text-lg font-light text-nocta-grey max-w-xl animate-fade-up" style="animation-delay: 0.5s; opacity: 0;">
          Répondons à toutes vos questions et construisons ensemble votre expérience.
        </p>
      </div>
    </section>

    <!-- 2-col: contact info + form -->
    <section class="bg-nocta-cream pb-28 lg:pb-40">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">

          <!-- Left: contact info -->
          <div class="reveal">
            <p class="font-sans text-xs tracking-[0.4em] uppercase text-nocta-grey mb-12">Coordonnées</p>

            <div class="mb-8">
              <p class="font-sans text-xs tracking-widest uppercase text-nocta-grey mb-3">Email</p>
              <a href="mailto:contact@noctaparis.fr" class="font-serif text-2xl lg:text-3xl font-light italic text-nocta-black hover:opacity-60 transition-opacity duration-200">
                contact@noctaparis.fr
              </a>
            </div>

            <div class="mb-14">
              <p class="font-sans text-xs tracking-widest uppercase text-nocta-grey mb-3">Téléphone</p>
              <a href="tel:+33650011616" class="font-serif text-2xl lg:text-3xl font-light italic text-nocta-black hover:opacity-60 transition-opacity duration-200">
                06 50 01 16 16
              </a>
            </div>

            <div class="border-t border-nocta-black/10 pt-8">
              <p class="font-sans text-sm font-light leading-relaxed text-nocta-grey">
                Nous répondons à chaque demande dans les 24 heures.
              </p>
            </div>
          </div>

          <!-- Right: form -->
          <form class="reveal flex flex-col gap-8" style="transition-delay: 0.15s">

            <!-- Prénom & Nom -->
            <div class="grid grid-cols-2 gap-4 lg:gap-6">
              <div class="flex flex-col gap-2">
                <label for="prenom" class="font-sans text-xs tracking-widest uppercase text-nocta-grey">Prénom</label>
                <input
                  id="prenom" name="prenom" type="text" required
                  class="bg-transparent border-b border-nocta-black/20 focus:border-nocta-black outline-none py-2.5 font-sans text-sm font-light text-nocta-black transition-colors duration-200"
                />
              </div>
              <div class="flex flex-col gap-2">
                <label for="nom" class="font-sans text-xs tracking-widest uppercase text-nocta-grey">Nom</label>
                <input
                  id="nom" name="nom" type="text" required
                  class="bg-transparent border-b border-nocta-black/20 focus:border-nocta-black outline-none py-2.5 font-sans text-sm font-light text-nocta-black transition-colors duration-200"
                />
              </div>
            </div>

            <!-- Email -->
            <div class="flex flex-col gap-2">
              <label for="email" class="font-sans text-xs tracking-widest uppercase text-nocta-grey">Email</label>
              <input
                id="email" name="email" type="email" required
                class="bg-transparent border-b border-nocta-black/20 focus:border-nocta-black outline-none py-2.5 font-sans text-sm font-light text-nocta-black transition-colors duration-200"
              />
            </div>

            <!-- Téléphone -->
            <div class="flex flex-col gap-2">
              <label for="telephone" class="font-sans text-xs tracking-widest uppercase text-nocta-grey">Téléphone</label>
              <input
                id="telephone" name="telephone" type="tel"
                class="bg-transparent border-b border-nocta-black/20 focus:border-nocta-black outline-none py-2.5 font-sans text-sm font-light text-nocta-black transition-colors duration-200"
              />
            </div>

            <!-- Type d'événement -->
            <div class="flex flex-col gap-2">
              <label for="type_evenement" class="font-sans text-xs tracking-widest uppercase text-nocta-grey">Type d'événement</label>
              <div class="relative">
                <select
                  id="type_evenement" name="type_evenement"
                  class="w-full appearance-none bg-transparent border-b border-nocta-black/20 focus:border-nocta-black outline-none py-2.5 pr-6 font-sans text-sm font-light text-nocta-black cursor-pointer transition-colors duration-200"
                >
                  <option value="" disabled selected></option>
                  <option value="private">NOCTA Private</option>
                  <option value="corporate">NOCTA Corporate</option>
                  <option value="signature">NOCTA Signature</option>
                </select>
                <svg class="absolute right-0 bottom-3.5 pointer-events-none text-nocta-grey" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>

            <!-- Date & Convives -->
            <div class="grid grid-cols-2 gap-4 lg:gap-6">
              <div class="flex flex-col gap-2">
                <label for="date" class="font-sans text-xs tracking-widest uppercase text-nocta-grey">Date envisagée</label>
                <input
                  id="date" name="date" type="date"
                  class="bg-transparent border-b border-nocta-black/20 focus:border-nocta-black outline-none py-2.5 font-sans text-sm font-light text-nocta-black transition-colors duration-200"
                />
              </div>
              <div class="flex flex-col gap-2">
                <label for="convives" class="font-sans text-xs tracking-widest uppercase text-nocta-grey">Nombre de convives</label>
                <input
                  id="convives" name="convives" type="number" min="1"
                  class="bg-transparent border-b border-nocta-black/20 focus:border-nocta-black outline-none py-2.5 font-sans text-sm font-light text-nocta-black transition-colors duration-200"
                />
              </div>
            </div>

            <!-- Budget estimatif -->
            <div class="flex flex-col gap-2">
              <label for="budget" class="font-sans text-xs tracking-widest uppercase text-nocta-grey">Budget estimatif</label>
              <div class="relative">
                <select
                  id="budget" name="budget"
                  class="w-full appearance-none bg-transparent border-b border-nocta-black/20 focus:border-nocta-black outline-none py-2.5 pr-6 font-sans text-sm font-light text-nocta-black cursor-pointer transition-colors duration-200"
                >
                  <option value="" disabled selected></option>
                  <option value="moins_2000">Moins de 2 000 €</option>
                  <option value="2000_5000">2 000 € – 5 000 €</option>
                  <option value="5000_10000">5 000 € – 10 000 €</option>
                  <option value="plus_10000">Plus de 10 000 €</option>
                </select>
                <svg class="absolute right-0 bottom-3.5 pointer-events-none text-nocta-grey" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>

            <!-- Message -->
            <div class="flex flex-col gap-2">
              <label for="message" class="font-sans text-xs tracking-widest uppercase text-nocta-grey">Message</label>
              <textarea
                id="message" name="message" rows="4"
                class="bg-transparent border-b border-nocta-black/20 focus:border-nocta-black outline-none py-2.5 font-sans text-sm font-light text-nocta-black transition-colors duration-200 resize-none"
              ></textarea>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="w-full font-sans text-sm font-light tracking-widest uppercase bg-nocta-black text-nocta-cream py-4 hover:bg-nocta-black/80 transition-all duration-300 mt-2"
            >
              Envoyer ma demande
            </button>

          </form>

        </div>
      </div>
    </section>

  </main>

  <Footer />

</Layout>

<style>
  input[type="date"]::-webkit-calendar-picker-indicator {
    opacity: 0.4;
    cursor: pointer;
  }
  input[type="number"]::-webkit-inner-spin-button,
  input[type="number"]::-webkit-outer-spin-button {
    opacity: 0.4;
  }
  select option {
    color: #000000;
  }
</style>
