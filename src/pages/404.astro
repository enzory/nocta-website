---
import Layout from '../layouts/layout.astro';
---

<Layout
  title="404 — Page introuvable · NOCTA"
  description="Cette page n'existe pas."
>

  <main class="bg-nocta-black min-h-screen flex flex-col items-center justify-center px-6 text-center">

    <p class="font-sans text-xs font-light tracking-[0.4em] uppercase text-nocta-cream/40 mb-8 animate-fade-up" style="animation-delay: 0.1s; opacity: 0;">
      Erreur
    </p>

    <h1 class="font-serif text-[8rem] lg:text-[14rem] font-light italic text-nocta-cream leading-none mb-6 animate-fade-up" style="animation-delay: 0.25s; opacity: 0;">
      404
    </h1>

    <p class="font-sans text-base lg:text-lg font-light text-nocta-cream/50 mb-14 animate-fade-up" style="animation-delay: 0.4s; opacity: 0;">
      Cette page n'existe pas.
    </p>

    <a
      href="/"
      class="inline-flex items-center font-sans text-sm font-light tracking-widest uppercase border border-nocta-cream/40 text-nocta-cream px-10 py-4 hover:border-nocta-cream hover:bg-nocta-cream hover:text-nocta-black transition-all duration-300 animate-fade-up"
      style="animation-delay: 0.55s; opacity: 0;"
    >
      Retourner à l'accueil
    </a>

  </main>

</Layout>
