{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "noctaparis.fr" }],
      "destination": "https://www.noctaparis.fr/:path*",
      "permanent": true
    },

    { "source": "/events", "destination": "/prestations/corporate", "permanent": true },
    { "source": "/nocta-signature", "destination": "/prestations/signature", "permanent": true },
    { "source": "/nocta-corporate", "destination": "/prestations/corporate", "permanent": true },
    { "source": "/nocta-private", "destination": "/prestations/private", "permanent": true },
    { "source": "/demande-de-devis", "destination": "/contact", "permanent": true },
    { "source": "/blog", "destination": "/journal", "permanent": true },
    { "source": "/blog/:slug*", "destination": "/journal/:slug*", "permanent": true },
    { "source": "/journal/traiteur-la-defense.md", "destination": "/journal/traiteur-la-defense", "permanent": true },

    { "source": "/a-propos", "destination": "/maison", "permanent": true },
    { "source": "/events/biologique-recherche-livraison-dejeuner-pause-gourmande", "destination": "/journal/buffet-entreprise-paris-livraison-hebdomadaire", "permanent": true },
    { "source": "/events/seminaire-petit-dejeuner-dejeuner-maison-americaine-marais", "destination": "/prestations/corporate", "permanent": true }
  ],
  "rewrites": [
    { "source": "/events/diner-prive-saint-tropez", "destination": "/api/gone" },
    { "source": "/mention-legal", "destination": "/api/gone" }
  ]
}
